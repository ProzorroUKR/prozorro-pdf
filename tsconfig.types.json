{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "emitDeclarationOnly": true,         // ✅ Only generate .d.ts files
    "outDir": "./dist/lib",              // ✅ Where to emit the types
    "declaration": true,
    "declarationMap": true,
    "stripInternal": true,
    "noEmit": false                      // ✅ Must be false to emit anything
  },
  "include": ["src"]
}